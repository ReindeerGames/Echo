# AI Provider Configuration
# Set AI_PROVIDER to 'ollama' to use local Ollama, or 'openai' (default) for OpenAI
AI_PROVIDER=openai
AI_MODEL=

# OpenAI Configuration (when AI_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Optional pricing overrides (USD per 1M tokens)
AI_RATE_GPT4O_MINI_INPUT_PER_M=0.15
AI_RATE_GPT4O_MINI_CACHED_INPUT_PER_M=0.075
AI_RATE_GPT4O_MINI_OUTPUT_PER_M=0.60

# Ollama Configuration (when AI_PROVIDER=ollama)
# OLLAMA_BASE_URL defaults to http://localhost:11434/v1
OLLAMA_BASE_URL=http://localhost:11434/v1
# Example models: gemma4:e2b, llama3.2, mistral, etc.
# AI_MODEL=gemma4:e2b

WA_BASE_URL=https://api.gochatapi.com
WA_INSTANCE=
WA_TOKEN=
WA_ALLOWED_NUMBERS=2782xxxxxxx,2783xxxxxxx
# Optional but strongly recommended: shared secret expected at payload.webhook_secret
WA_WEBHOOK_SECRET=
# Optional WhatsApp status check resilience tuning
WA_STATUS_RETRIES=3
WA_STATUS_TIMEOUT_MS=10000
WA_STATUS_RETRY_DELAY_MS=1200
# Optional WhatsApp send timeout (GoChat delivery ack can take a few seconds)
WA_SEND_TIMEOUT_MS=30000

PORT=3000
DOCKER_SOCKET=/var/run/docker.sock

# Debug Options
# Set to 'true' to enable detailed webhook logging (headers, body, parsed data)
DEBUG_WEBHOOKS=false
